# =============================================================================
# LiteBase Configuration
# =============================================================================
# Copy this file to .env and update the values before running docker compose up

# ---------- Security (REQUIRED - change these!) ----------
POSTGRES_PASSWORD=change-me-to-a-secure-password
JWT_SECRET=change-me-to-at-least-32-characters-long-secret
STUDIO_PASSWORD=change-me-admin-password

# ---------- SMTP (Optional - for email verification) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=LiteBase

# ---------- Studio ----------
STUDIO_PORT=3000

# ---------- Advanced (usually no need to change) ----------
POSTGRES_USER=litebase
POSTGRES_DB=litebase_meta
PG_PORT=5432
PGBOUNCER_PORT=6432
